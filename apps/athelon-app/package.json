{
  "name": "athelon-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:prod": "tsc --noEmit && vite build",
    "vercel:build": "pnpm run build:prod",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "seed:e2e:scheduler-stories": "node scripts/seed-scheduler-stories.mjs",
    "seed:repair-station": "node scripts/seed-repair-station-scenario.mjs",
    "seed:audit:repair-station": "node scripts/audit-repair-station-seed.mjs",
    "spec:sync:bug-hunter": "node scripts/bug-hunter-sync-master-build.mjs",
    "test:e2e:wave:bootstrap": "pnpm exec playwright test tests/e2e/wave-first-user-bootstrap.spec.ts --project=chromium-authenticated",
    "test:e2e:wave:internal-empty-org": "pnpm exec playwright test tests/e2e/wave-empty-org-internal-routes.spec.ts --project=chromium-authenticated",
    "test:e2e:wave:internal-seeded": "pnpm exec playwright test tests/e2e/wave-seeded-internal-routes.spec.ts --project=chromium-authenticated",
    "test:e2e:wave:empty-state": "pnpm exec playwright test tests/e2e/wave-empty-state-cta.spec.ts tests/e2e/wave-noop-action-regression.spec.ts --project=chromium-authenticated",
    "test:e2e:wave:artifacts": "pnpm exec playwright test tests/e2e/wave-critical-path-artifacts.spec.ts --project=chromium-authenticated",
    "test:e2e:wave:scheduler-stories": "pnpm run seed:e2e:scheduler-stories && pnpm exec playwright test tests/e2e/wave8-scheduler-seeded-user-stories.spec.ts tests/e2e/wave8-quote-conversion-regression.spec.ts tests/e2e/wave8-quote-labor-kits-user-stories.spec.ts --project=chromium-authenticated",
    "test:e2e:wave:gate": "pnpm exec playwright test tests/e2e/wave-first-user-bootstrap.spec.ts tests/e2e/wave-empty-org-internal-routes.spec.ts tests/e2e/wave-seeded-internal-routes.spec.ts tests/e2e/wave-empty-state-cta.spec.ts tests/e2e/wave-noop-action-regression.spec.ts --project=chromium-authenticated",
    "qa:first-user-gate": "pnpm run typecheck && pnpm run test:e2e:wave:gate",
    "data:parse-national-part145": "node scripts/generate-national-part145.mjs",
    "spec:export:derived": "node scripts/export-feature-spec-derived.mjs",
    "agentic:reviewer:quick": "node scripts/agentic/reviewer.mjs propose --mode quick",
    "agentic:reviewer:deep": "node scripts/agentic/reviewer.mjs propose --mode deep",
    "agentic:reviewer:apply": "node scripts/agentic/reviewer.mjs apply",
    "agentic:orchestrator:start": "node scripts/agentic/orchestrator.mjs start",
    "agentic:orchestrator:stop": "node scripts/agentic/orchestrator.mjs stop",
    "agentic:orchestrator:tick": "node scripts/agentic/orchestrator.mjs tick",
    "agentic:session:bypass": "node scripts/agentic/local-session-bypass.mjs adopt",
    "agentic:session:next": "node scripts/agentic/local-session-bypass.mjs next",
    "agentic:queue:add": "node scripts/agentic/queue.mjs add",
    "agentic:queue:list": "node scripts/agentic/queue.mjs list",
    "agentic:queue:complete": "node scripts/agentic/queue.mjs complete",
    "test:agentic": "node --test scripts/agentic/tests/*.test.mjs",
    "test:camp-linkage": "node --test scripts/camp-linkage/*.test.mjs",
    "test:scheduling-helpers": "node --test scripts/scheduling/*.test.mjs",
    "test:due-list-helpers": "node --test scripts/due-list/*.test.mjs",
    "data:parse-airports": "node scripts/parse-airport-data.mjs"
  },
  "dependencies": {
    "@clerk/backend": "^2.33.0",
    "@clerk/clerk-react": "^5.61.1",
    "@clerk/themes": "^2.4.55",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@react-pdf/renderer": "^4.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.32.0",
    "convex-helpers": "^0.1.113",
    "html5-qrcode": "^2.3.8",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^0.575.0",
    "next-themes": "^0.4.6",
    "openai": "^6.29.0",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^6.0.0",
    "recharts": "^3.7.0",
    "resend": "^6.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "workbox-window": "^7.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clerk/testing": "^1.14.1",
    "@playwright/test": "^1.58.2",
    "@react-pdf/types": "^2.9.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.0.0",
    "dotenv": "^17.3.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.1",
    "xlsx": "^0.18.5"
  }
}
