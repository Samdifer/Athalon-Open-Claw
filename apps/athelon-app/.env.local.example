# ============================================================
# Athelon MRO — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# ============================================================

# Convex
# Get from: https://dashboard.convex.dev → Your Project → Settings → URL
VITE_CONVEX_URL=https://your-project.convex.cloud

# Clerk — Publishable Key
# Get from: https://dashboard.clerk.com → Your App → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk JWT issuer domain (for Convex auth config — server-side only)
# Get from: https://dashboard.clerk.com → Your App → JWT Templates → Convex
CLERK_JWT_ISSUER_DOMAIN=https://your-instance.clerk.accounts.dev

# Clerk Secret Key (required for Playwright global setup persona token generation)
# Get from: https://dashboard.clerk.com → Your App → API Keys
CLERK_SECRET_KEY=sk_test_...

# NOTE: Redirect URLs are now configured as ClerkProvider props in main.tsx
# (signInUrl="/sign-in", signUpUrl="/sign-up", afterSignInUrl="/dashboard", afterSignUpUrl="/dashboard")
# No env vars needed for those.

# Playwright persona emails (Wave 0 first-time-user coverage)
# Unlinked = authenticated Clerk user with no technician/org bootstrap.
PLAYWRIGHT_UNLINKED_EMAIL=athelon.e2e+unlinked_clerk_test@gmail.com

# Empty org admin = bootstrapped org/admin but no domain business records.
PLAYWRIGHT_EMPTY_ORG_EMAIL=athelon.e2e+empty_org_clerk_test@gmail.com

# Seeded admin = existing data-rich org for broad regression coverage.
PLAYWRIGHT_SEEDED_EMAIL=athelon.e2e+clerk_test@gmail.com

# Optional test password used when setting/resetting persona passwords.
PLAYWRIGHT_TEST_PASSWORD=ClerkTest123!
