{
  "name": "athelon-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "seed:e2e:scheduler-stories": "node scripts/seed-scheduler-stories.mjs",
    "seed:repair-station": "node scripts/seed-repair-station-scenario.mjs",
    "seed:audit:repair-station": "node scripts/audit-repair-station-seed.mjs",
    "spec:sync:bug-hunter": "node scripts/bug-hunter-sync-master-build.mjs",
    "test:e2e:wave:bootstrap": "npx playwright test e2e/wave-first-user-bootstrap.spec.ts --project=chromium-authenticated",
    "test:e2e:wave:internal-empty-org": "npx playwright test e2e/wave-empty-org-internal-routes.spec.ts --project=chromium-authenticated",
    "test:e2e:wave:internal-seeded": "npx playwright test e2e/wave-seeded-internal-routes.spec.ts --project=chromium-authenticated",
    "test:e2e:wave:empty-state": "npx playwright test e2e/wave-empty-state-cta.spec.ts e2e/wave-noop-action-regression.spec.ts --project=chromium-authenticated",
    "test:e2e:wave:artifacts": "npx playwright test e2e/wave-critical-path-artifacts.spec.ts --project=chromium-authenticated",
    "test:e2e:wave:scheduler-stories": "npm run seed:e2e:scheduler-stories && npx playwright test e2e/wave8-scheduler-seeded-user-stories.spec.ts e2e/wave8-quote-conversion-regression.spec.ts e2e/wave8-quote-labor-kits-user-stories.spec.ts --project=chromium-authenticated",
    "test:e2e:wave:gate": "npx playwright test e2e/wave-first-user-bootstrap.spec.ts e2e/wave-empty-org-internal-routes.spec.ts e2e/wave-seeded-internal-routes.spec.ts e2e/wave-empty-state-cta.spec.ts e2e/wave-noop-action-regression.spec.ts --project=chromium-authenticated",
    "qa:first-user-gate": "npm run typecheck && npm run test:e2e:wave:gate",
    "spec:export:derived": "node scripts/export-feature-spec-derived.mjs"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.1",
    "@clerk/themes": "^2.4.55",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@react-pdf/renderer": "^4.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.32.0",
    "convex-helpers": "^0.1.113",
    "html5-qrcode": "^2.3.8",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^0.575.0",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^6.0.0",
    "recharts": "^3.7.0",
    "resend": "^6.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clerk/testing": "^1.14.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.0.0",
    "dotenv": "^17.3.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite": "^6.0.0"
  }
}
