{
  "name": "athalon-open-claw-workspace",
  "private": true,
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "dev:athelon": "pnpm --dir apps/athelon-app dev",
    "build:athelon": "pnpm --dir apps/athelon-app build",
    "typecheck:athelon": "pnpm --dir apps/athelon-app typecheck"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  }
}
